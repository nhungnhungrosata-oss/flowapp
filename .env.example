# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_ENV=development
AUTH_SECRET=replace-with-a-long-random-secret
DEV_USER_ID=dev-user
DEV_WORKSPACE_ID=dev-workspace

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/adforge?schema=public

# Google Flow via useapi.net (server only)
USEAPI_BASE_URL=https://api.useapi.net/v1/google-flow
USEAPI_TOKEN=
USEAPI_ACCOUNT_EMAIL=
USEAPI_TIMEOUT_MS=45000
USEAPI_WEBHOOK_SECRET=replace-with-random-webhook-secret

# Redis / BullMQ
REDIS_URL=redis://localhost:6379

# S3 compatible storage
S3_REGION=auto
S3_ENDPOINT=
S3_BUCKET=adforge-private
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=

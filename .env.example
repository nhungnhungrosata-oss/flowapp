# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
AUTH_SECRET=replace-with-a-long-random-secret
DEV_USER_ID=dev-user
DEV_WORKSPACE_ID=dev-workspace

# Shared AI providers for every app
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
USEAPI_TOKEN=
USEAPI_ACCOUNT_EMAIL=
USEAPI_TIMEOUT_MS=45000

# Database - required when saving users, projects and generations
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/adforge?schema=public

# Webhook - required when enabling provider webhooks
USEAPI_WEBHOOK_SECRET=replace-with-random-webhook-secret

# Redis / BullMQ - required for background workers
REDIS_URL=redis://localhost:6379

# S3-compatible storage - required for permanent media storage
S3_REGION=auto
S3_ENDPOINT=
S3_BUCKET=adforge-private
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false

# Stripe - required only when billing is enabled
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=

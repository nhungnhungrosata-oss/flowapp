generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum Plan {
  FREE
  PRO
  BUSINESS
}

enum ProjectStatus {
  DRAFT
  PROCESSING
  READY
  FAILED
  ARCHIVED
}

enum GenerationType {
  COMPOSITE_IMAGE
  VIDEO
  VOICE
  SUBTITLE
  EXPORT
}

enum GenerationStatus {
  DRAFT
  QUEUED
  SUBMITTED
  PROCESSING
  SUCCEEDED
  FAILED
  CANCELLED
  EXPIRED
}

enum AssetKind {
  PRODUCT_IMAGE
  CHARACTER_IMAGE
  COMPOSITE_IMAGE
  VIDEO
  AUDIO
  SUBTITLE
  THUMBNAIL
  BRAND_LOGO
  OTHER
}

enum AssetSource {
  USER_UPLOAD
  PROVIDER
  GENERATED
  SYSTEM
}

enum CreditDirection {
  CREDIT
  DEBIT
  REFUND
}

enum CreditReason {
  SIGNUP
  MONTHLY_RENEWAL
  PURCHASE
  GENERATION
  REFUND
  ADMIN_ADJUSTMENT
}

model User {
  id          String       @id @default(cuid())
  email       String       @unique
  name        String?
  image       String?
  memberships Membership[]
  projects    Project[]
  assets      Asset[]
  apiUsage    ApiUsage[]
  auditLogs   AuditLog[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Workspace {
  id           String              @id @default(cuid())
  name         String
  slug         String              @unique
  plan         Plan                @default(FREE)
  memberships  Membership[]
  projects     Project[]
  brandKits    BrandKit[]
  characters   Character[]
  creditWallet CreditWallet?
  subscription Subscription?
  templates    WorkspaceTemplate[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
}

model Membership {
  id          String    @id @default(cuid())
  userId      String
  workspaceId String
  role        Role      @default(MEMBER)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([userId, workspaceId])
}

model Subscription {
  id                     String    @id @default(cuid())
  workspaceId            String    @unique
  workspace              Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  provider               String    @default("stripe")
  providerCustomerId     String?
  providerSubscriptionId String?
  status                 String    @default("inactive")
  currentPeriodEnd       DateTime?
  cancelAtPeriodEnd      Boolean   @default(false)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}

model CreditWallet {
  id           String              @id @default(cuid())
  workspaceId  String              @unique
  workspace    Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  balance      Int                 @default(0)
  reserved     Int                 @default(0)
  transactions CreditTransaction[]
  updatedAt    DateTime            @updatedAt
}

model CreditTransaction {
  id            String          @id @default(cuid())
  walletId      String
  wallet        CreditWallet    @relation(fields: [walletId], references: [id], onDelete: Cascade)
  direction     CreditDirection
  reason        CreditReason
  amount        Int
  generationId String?
  note          String?
  metadata      Json?
  createdAt     DateTime        @default(now())

  @@index([walletId, createdAt])
}

model Project {
  id                  String        @id @default(cuid())
  workspaceId         String
  userId              String
  workspace           Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user                User          @relation(fields: [userId], references: [id], onDelete: Restrict)
  name                String
  industry            String?
  status              ProjectStatus @default(DRAFT)
  aspectRatio         String        @default("9:16")
  targetDuration      Int           @default(8)
  productName         String?
  productNotes        String?
  selectedCharacterId String?
  selectedSceneId     String?
  script              Script?
  generations         Generation[]
  assets              Asset[]
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([workspaceId, updatedAt])
}

model BrandKit {
  id           String    @id @default(cuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name         String
  logoAssetId  String?
  primaryColor String    @default("#7C3AED")
  accentColor  String    @default("#22D3EE")
  fontFamily   String    @default("Inter")
  toneOfVoice  String?
  ctaExamples  String[]
  bannedWords  String[]
  isDefault    Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Character {
  id             String    @id @default(cuid())
  workspaceId    String
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  providerRef    String?
  previewAssetId String?
  voiceRef       String?
  tags           String[]
  isSystem       Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model SceneTemplate {
  id                  String              @id @default(cuid())
  slug                String              @unique
  name                String
  industry            String
  description         String?
  promptTemplate      String
  videoPromptTemplate String
  previewUrl          String?
  tags                String[]
  active              Boolean             @default(true)
  workspaces          WorkspaceTemplate[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
}

model WorkspaceTemplate {
  workspaceId String
  templateId  String
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  template    SceneTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  favorite    Boolean       @default(false)

  @@id([workspaceId, templateId])
}

model Script {
  id            String   @id @default(cuid())
  projectId     String   @unique
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  hook          String
  body          String
  cta           String
  voiceoverText String
  caption       String
  hashtags      String[]
  subtitleJson  Json?
  language      String   @default("vi")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Generation {
  id              String             @id @default(cuid())
  projectId       String
  project         Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type            GenerationType
  prompt          String?
  negativePrompt  String?
  model           String?
  parametersJson  Json?
  status          GenerationStatus   @default(DRAFT)
  providerStatus  String?
  providerJobId   String?            @unique
  providerAccount String?
  errorCode       String?
  errorMessage    String?
  attemptCount    Int                @default(0)
  creditCost      Int                @default(0)
  idempotencyKey  String?            @unique
  submittedAt     DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  lastCheckedAt   DateTime?
  outputs         GenerationOutput[]
  usage           ApiUsage[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([projectId, createdAt])
  @@index([status, lastCheckedAt])
}

model Asset {
  id              String             @id @default(cuid())
  userId          String
  projectId       String?
  user            User               @relation(fields: [userId], references: [id], onDelete: Restrict)
  project         Project?           @relation(fields: [projectId], references: [id], onDelete: SetNull)
  kind            AssetKind
  source          AssetSource
  providerAssetId String?
  originalUrl     String?
  storageKey      String?
  mimeType        String
  width           Int?
  height          Int?
  duration        Float?
  size            BigInt?
  metadata        Json?
  outputs         GenerationOutput[]
  createdAt       DateTime           @default(now())

  @@index([userId, createdAt])
  @@index([projectId, createdAt])
}

model GenerationOutput {
  id           String     @id @default(cuid())
  generationId String
  assetId      String
  outputIndex  Int        @default(0)
  metadataJson Json?
  generation   Generation @relation(fields: [generationId], references: [id], onDelete: Cascade)
  asset        Asset      @relation(fields: [assetId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([generationId, outputIndex])
}

model ApiUsage {
  id            String      @id @default(cuid())
  userId        String
  generationId  String?
  user          User        @relation(fields: [userId], references: [id], onDelete: Restrict)
  generation    Generation? @relation(fields: [generationId], references: [id], onDelete: SetNull)
  operation     String
  success       Boolean
  latencyMs     Int
  providerCode  String?
  estimatedCost Decimal?    @db.Decimal(12, 6)
  createdAt     DateTime    @default(now())

  @@index([userId, createdAt])
}

model IdempotencyKey {
  id           String   @id @default(cuid())
  workspaceId  String
  key          String
  requestHash  String
  responseJson Json?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@unique([workspaceId, key])
}

model WebhookEvent {
  id          String    @id @default(cuid())
  provider    String
  externalId  String?
  payloadHash String
  payload     Json
  processedAt DateTime?
  createdAt   DateTime  @default(now())

  @@unique([provider, payloadHash])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String
  entityId   String?
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())

  @@index([createdAt])
}
